[gd_resource type="Resource" script_class="ScreenEffectDefinition" format=3 uid="uid://ddafwlfmjjw3y"]

[ext_resource type="Script" uid="uid://o2diwtsvvjoy" path="res://visuals/screen_effects/definitions/screen_effect_definition.gd" id="1_definition"]
[ext_resource type="Script" uid="uid://bui5peaqwo1o4" path="res://visuals/screen_effects/definitions/screen_effect_parameter_editability_rule.gd" id="2_rule"]
[ext_resource type="Shader" uid="uid://cwadrf65yyjk3" path="res://visuals/screen_effects/shaders/color_quantization.gdshader" id="3_shader"]

[sub_resource type="Resource" id="EditabilityRule_shared"]
script = ExtResource("2_rule")
condition_parameter = &"quantization_mode"
editable_values = [0]
target_parameters = Array[StringName]([&"color_levels"])

[sub_resource type="Resource" id="EditabilityRule_per_channel"]
script = ExtResource("2_rule")
condition_parameter = &"quantization_mode"
editable_values = [1]
target_parameters = Array[StringName]([&"red_levels", &"green_levels", &"blue_levels"])

[sub_resource type="Resource" id="EditabilityRule_dither"]
script = ExtResource("2_rule")
condition_parameter = &"dither_enabled"
editable_values = [true]
target_parameters = Array[StringName]([&"dither_mode", &"dither_strength", &"dither_scale"])

[resource]
script = ExtResource("1_definition")
display_name = "Color Quantization"
shader = ExtResource("3_shader")
editability_rules = Array[ExtResource("2_rule")]([SubResource("EditabilityRule_shared"), SubResource("EditabilityRule_per_channel"), SubResource("EditabilityRule_dither")])
