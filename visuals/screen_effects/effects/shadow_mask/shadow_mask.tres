[gd_resource type="Resource" script_class="ScreenEffectDefinition" format=3 uid="uid://c1u2wxbe6cpgs"]

[ext_resource type="Script" uid="uid://o2diwtsvvjoy" path="res://visuals/screen_effects/screen_effect_definition.gd" id="1_definition"]
[ext_resource type="Script" uid="uid://bui5peaqwo1o4" path="res://visuals/screen_effects/screen_effect_parameter_activation_rule.gd" id="2_rule"]
[ext_resource type="Shader" uid="uid://c2owlk4idxt70" path="res://visuals/screen_effects/effects/shadow_mask/shadow_mask.gdshader" id="3_shader"]

[sub_resource type="Resource" id="ActivationRule_dot"]
script = ExtResource("2_rule")
condition_parameter = &"mask_type"
active_values = [0, 1]
target_parameters = Array[StringName]([&"dot_size"])

[sub_resource type="Resource" id="ActivationRule_slot"]
script = ExtResource("2_rule")
condition_parameter = &"mask_type"
active_values = [2, 3, 4]
target_parameters = Array[StringName]([&"slot_unit_gap_x", &"slot_unit_gap_y"])

[resource]
script = ExtResource("1_definition")
id = &"shadow_mask"
display_name = "Shadow Mask"
shader = ExtResource("3_shader")
activation_rules = Array[ExtResource("2_rule")]([SubResource("ActivationRule_dot"), SubResource("ActivationRule_slot")])
